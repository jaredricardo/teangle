{%- comment -%}
# Custom robots.txt for teangle.ca
# Built by Raman Singh
{%- endcomment -%}

{%- for group in robots.rules -%}
  {{- group.user_agent -}}

  {%- for rule in group.rules -%}
    {{- rule -}}
  {%- endfor -%}

  {%- comment -%} 
    Custom Rules: Ensure products are allowed 
  {%- endcomment -%}
  {%- if group.user_agent.value == '*' -%}
    Allow: /products/
    Allow: /fr/products/
    Disallow: /collections/*+*
    Disallow: /collections/*%2b*
  {%- endif -%}

  {{- group.sitemap -}}
{%- endfor -%}