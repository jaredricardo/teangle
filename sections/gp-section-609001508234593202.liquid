      <script id="custom-js-grpU1p24o4">
        try {
          (function () {
  /* =========================================================
     PART 1: MOONBUNDLE PRICE -> GEMPAGES BUTTON PRICE (ORIGINAL)
     ========================================================= */

  // 👉 Button price element (ADD TO CART)
  var BTN_PRICE_SELECTOR = ".gp-price.gp-money.gp-button-price.gp-text-instant";

  // 👉 Active MoonBundle option
  var ACTIVE_OPTION_SELECTOR =
    ".moonbundle-option.moonbundle-option-active, \
     .moonbundle-option-active, \
     .moonbundle-option.is-active, \
     .moonbundle-option.active";

  // 👉 Possible price elements (sale + old both might match, so we filter below)
  var PRICE_CANDIDATES_SELECTOR =
    ".moonbundle-option-single-price, \
     .moonbundle-option-single-pr, \
     .moonbundle-option-price";

  // 👉 Old/compare price selectors (we will exclude these)
  var OLD_PRICE_SELECTOR =
    ".moonbundle-option-old-price, \
     .moonbundle-option-compare-price, \
     .moonbundle-option-compare-at-price, \
     [class*='old-price'], \
     [class*='compare']";

  function $(sel, root) {
    return (root || document).querySelector(sel);
  }

  function $all(sel, root) {
    return Array.prototype.slice.call((root || document).querySelectorAll(sel));
  }

  // ✅ Extract number and force "AUD $"
  function normalizeAUD(text) {
    if (!text) return "";
    var m = String(text).match(/(\d+(?:\.\d{1,2})?)/);
    if (!m) return "";
    return "AUD $" + m[1];
  }

  // ✅ Detect crossed-out/old prices via DOM + CSS
  function isOldOrCrossed(el) {
    if (!el) return true;

    // inside a known old/compare wrapper
    if (el.closest && el.closest(OLD_PRICE_SELECTOR)) return true;

    // CSS line-through check
    try {
      var cs = window.getComputedStyle(el);
      var td = (cs.textDecorationLine || cs.textDecoration || "").toLowerCase();
      if (td.indexOf("line-through") > -1) return true;
    } catch (e) {}

    return false;
  }

  function getActiveBundleSalePrice() {
    var active = $(ACTIVE_OPTION_SELECTOR);
    if (!active) return "";

    var wrapper = active.closest(".moonbundle-option-wrapper") || active;

    // get all possible price nodes inside this wrapper
    var candidates = $all(PRICE_CANDIDATES_SELECTOR, wrapper);
    if (!candidates.length) return "";

    // filter out old/crossed ones
    var valid = candidates.filter(function (el) {
      return !isOldOrCrossed(el) && String(el.textContent || "").trim().length;
    });

    // If nothing left, fallback to last candidate
    var chosen = valid.length ? valid[valid.length - 1] : candidates[candidates.length - 1];

    return normalizeAUD(chosen.textContent);
  }

  function updateButtonPrice() {
    var btnPrice = $(BTN_PRICE_SELECTOR);
    if (!btnPrice) return;

    var salePrice = getActiveBundleSalePrice();
    if (!salePrice) return;

    if (btnPrice.textContent.trim() !== salePrice) {
      btnPrice.textContent = salePrice;
    }
  }

  function bindPriceSync() {
    updateButtonPrice();

    document.addEventListener(
      "click",
      function () {
        setTimeout(updateButtonPrice, 30);
      },
      true
    );

    document.addEventListener(
      "change",
      function () {
        setTimeout(updateButtonPrice, 30);
      },
      true
    );

    var target = document.querySelector(".moonbundle-box") || document.body;

    new MutationObserver(function () {
      updateButtonPrice();
    }).observe(target, {
      childList: true,
      subtree: true,
      characterData: true
    });
  }

  /* =========================================================
     PART 2: SKIP KACHING CART FLASH + DIRECT CHECKOUT
     ========================================================= */

  // ✅ Target your GemPages button class
  var GP_BTN_CLASS = "grpU1p24o4";
  var ATC_SELECTOR = "." + GP_BTN_CLASS;

  function hardHideKaching() {
    var el = document.getElementById("kaching-cart");
    if (!el) return;

    el.style.setProperty("display", "none", "important");
    el.style.setProperty("opacity", "0", "important");
    el.style.setProperty("visibility", "hidden", "important");
    el.style.setProperty("pointer-events", "none", "important");

    el.classList.remove("active");
    el.setAttribute("data-open", "false");

    var overlay = el.querySelector(".kaching-cart__overlay");
    if (overlay) {
      overlay.style.setProperty("display", "none", "important");
      overlay.style.setProperty("opacity", "0", "important");
      overlay.style.setProperty("visibility", "hidden", "important");
      overlay.style.setProperty("pointer-events", "none", "important");
    }
  }

  function lockKachingHidden(ms) {
    var start = Date.now();
    var t = setInterval(function () {
      hardHideKaching();
      if (Date.now() - start > ms) clearInterval(t);
    }, 30);
  }

  var redirecting = false;

  async function getCartCount() {
    try {
      var res = await fetch("/cart.js", { credentials: "same-origin" });
      if (!res.ok) return null;
      var cart = await res.json();
      return typeof cart.item_count === "number" ? cart.item_count : null;
    } catch (e) {
      return null;
    }
  }

  async function waitForCartUpdate(oldCount, timeoutMs) {
    var start = Date.now();
    while (Date.now() - start < timeoutMs) {
      var newCount = await getCartCount();
      if (newCount !== null) {
        if (newCount > oldCount) return true;
        if (oldCount === 0 && newCount > 0) return true;
      }
      await new Promise(function (r) { setTimeout(r, 200); });
    }
    return false;
  }

  function bindDirectCheckout() {
    document.addEventListener(
      "click",
      function (e) {
        var btn = e.target.closest(ATC_SELECTOR);
        if (!btn) return;

        // only GemPages add-to-cart button
        if (!btn.classList.contains("gp-button-atc")) return;

        if (redirecting) return;
        redirecting = true;

        // hide cart instantly to prevent flash
        hardHideKaching();
        lockKachingHidden(3500);

        (async function () {
          var before = await getCartCount();
          var oldCount = before === null ? 0 : before;

          await waitForCartUpdate(oldCount, 6000);

          hardHideKaching();
          window.location.href = "/checkout";
        })();
      },
      true
    );

    // safety: if Kaching tries to open anyway, hide again
    var obs = new MutationObserver(function () {
      var el = document.getElementById("kaching-cart");
      if (!el) return;

      if (el.classList.contains("active") || el.getAttribute("data-open") === "true") {
        hardHideKaching();
      }
    });

    obs.observe(document.documentElement, { childList: true, subtree: true, attributes: true });
  }

  /* =========================================================
     INIT
     ========================================================= */
  function initAll() {
    bindPriceSync();
    bindDirectCheckout();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAll);
  } else {
    initAll();
  }
})();

        } catch(err){}
      </script>
    
