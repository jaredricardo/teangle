        <div class="qty-label">bag</div>
        <div class="qty-discount" style="color:#9ca3af !important">$68.00</div>
        <div class="qty-original">&nbsp;</div>
      </div>

      <div class="qty-card active" onclick="bwQty(1)">
        <div class="qty-badge">Most popular</div>
        <div class="qty-number">2</div>
        <div class="qty-label">bags</div>
        <div class="qty-discount">$61.20/bag</div>
        <div class="qty-original">Save 10%</div>
      </div>

      <div class="qty-card" onclick="bwQty(2)">
        <div class="qty-number">3</div>
        <div class="qty-label">bags</div>
        <div class="qty-discount">$57.80/bag</div>
        <div class="qty-original">Save 15%</div>
