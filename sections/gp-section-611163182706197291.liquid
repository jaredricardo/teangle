      <div>
    <!-- BUNDLE LEFT SIDE — Product Image Block -->
<!-- Paste into the LEFT column Custom Code block in GemPages -->

<style>
  .bw-img-wrap{width:100% !important;max-width:480px !important;margin:0 auto !important}
  .bw-main-img-box{width:100% !important;aspect-ratio:1/1 !important;border-radius:16px !important;overflow:hidden !important;background:#f3f4f6 !important;position:relative !important}
  .bw-main-img-box img{width:100% !important;height:100% !important;object-fit:cover !important;position:absolute !important;top:0 !important;left:0 !important;opacity:0 !important;transition:opacity 0.3s ease !important}
  .bw-main-img-box img.bw-active{opacity:1 !important}
  .bw-thumb-row{display:flex !important;gap:8px !important;margin-top:12px !important;justify-content:center !important}
  .bw-thumb{width:64px !important;height:64px !important;border-radius:8px !important;object-fit:cover !important;cursor:pointer !important;border:2px solid transparent !important;opacity:0.55 !important;transition:all 0.15s !important;background:#f3f4f6 !important}
  .bw-thumb.bw-active{border-color:#1D9E75 !important;opacity:1 !important}
  .bw-skeleton{width:100% !important;aspect-ratio:1/1 !important;border-radius:16px !important;background:#e5e7eb !important;animation:bwPulse 1.4s ease-in-out infinite !important}
  @keyframes bwPulse{0%,100%{opacity:1}50%{opacity:0.4}}
</style>

<div class="bw-img-wrap">
  <div id="bw-skeleton" class="bw-skeleton"></div>
  <div class="bw-main-img-box" id="bw-main-box" style="display:none">
    <img id="bw-img-0" class="bw-active" src="" alt="Original Matcha Collagen" />
    <img id="bw-img-1" src="" alt="Chocolate Matcha Collagen" />
    <img id="bw-img-2" src="" alt="Vanilla Matcha Collagen" />
  </div>
  <div class="bw-thumb-row" id="bw-thumb-row" style="display:none">
    <img class="bw-thumb bw-active" id="bw-thumb-0" src="" alt="Original" onclick="bwImgSelect(0)" />
    <img class="bw-thumb" id="bw-thumb-1" src="" alt="Chocolate" onclick="bwImgSelect(1)" />
    <img class="bw-thumb" id="bw-thumb-2" src="" alt="Vanilla" onclick="bwImgSelect(2)" />
  </div>
</div>

<script>
(function(){
  var PRODUCT_IDS = [7549676290130, 7549675438162, 7545437913170];

  function setImage(idx, url){
    document.getElementById('bw-img-'+idx).src = url;
    document.getElementById('bw-thumb-'+idx).src = url;
  }

  function showUI(){
    document.getElementById('bw-skeleton').style.display = 'none';
    document.getElementById('bw-main-box').style.display = 'block';
    document.getElementById('bw-thumb-row').style.display = 'flex';
  }

  fetch('/products.json?limit=250')
    .then(function(r){ return r.json(); })
    .then(function(data){
      var products = data.products || [];
      PRODUCT_IDS.forEach(function(id, idx){
        var match = products.find(function(p){ return p.id === id; });
        if(match && match.images && match.images.length > 0){
          setImage(idx, match.images[0].src);
        }
      });
      showUI();
    })
    .catch(function(){ showUI(); });

  window.bwUpdateImage = function(idx){
    for(var i=0;i<3;i++){
      var img = document.getElementById('bw-img-'+i);
      var thumb = document.getElementById('bw-thumb-'+i);
      if(img) img.classList.toggle('bw-active', i===idx);
      if(thumb) thumb.classList.toggle('bw-active', i===idx);
    }
  };

  window.bwImgSelect = function(idx){
    bwUpdateImage(idx);
    if(typeof window.bwFlavor === 'function'){ window.bwFlavor(idx); }
  };
})();
</script>
