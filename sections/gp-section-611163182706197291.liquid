      <div class="gift-name" id="bw-gift-name">Loading...</div>
    </div>
    <div class="gift-price">FREE<br><span style="text-decoration:line-through;color:#9ca3af;font-size:11px;font-weight:400" id="bw-gift-orig"></span></div>
  </div>

  <!-- Summary & CTA -->
  <div class="summary-box">
    <div class="sum-row">
      <span id="bw-items">2 bags · Original Matcha</span>
      <span id="bw-orig">$136.00</span>
