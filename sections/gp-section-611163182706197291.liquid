    <button class="add-btn" id="bw-btn" onclick="bwAddCart()">Buy Now →</button>
  </div>

</div>

<script>
(function(){
  // ── CONFIG ─────────────────────────────────────────────
  var UNIT_PRICE = 68.00;
  var FLAVORS    = ['Original Matcha','Chocolate Matcha','Vanilla Matcha'];
  var PRODUCT_IDS = [7549676290130, 7549675438162, 7545437913170];
  var VARIANT_IDS = [
    42318931066962,   // Original Matcha Collagen
    42318929264722,   // Chocolate Matcha Collagen
    42311457996882,   // Vanilla Matcha Collagen
  ];

  // qty index:   0=1bag   1=2bags   2=3bags
  var QTYS      = [1,       2,        3      ];
  var DISCOUNTS = [0,       0.10,     0.15   ];

  // Free gift — added automatically when qty >= 2
  var FREE_GIFT_VARIANT_ID = 42222841364562;
  // ───────────────────────────────────────────────────────

  var selF = 0, selQ = 1;

  // Auto-fetch product images from Shopify storefront
  fetch('/products.json?limit=250')
    .then(function(r){ return r.json(); })
    .then(function(data){
      var products = data.products || [];
      PRODUCT_IDS.forEach(function(id, idx){
        var match = products.find(function(p){ return p.id === id; });
        if(match && match.images && match.images.length > 0){
          var el = document.getElementById('bw-fimg-'+idx);
          if(el) el.src = match.images[0].src;
        }
      });
      // Fetch free gift product details
      var gift = products.find(function(p){ return p.id === 7508173815890; });
      if(gift){
        var giftImg = document.getElementById('bw-gift-img');
        var giftName = document.getElementById('bw-gift-name');
        var giftOrig = document.getElementById('bw-gift-orig');
        if(giftImg && gift.images && gift.images.length > 0) giftImg.src = gift.images[0].src;
        if(giftName) giftName.textContent = gift.title;
        if(giftOrig && gift.variants && gift.variants.length > 0){
          var origPrice = parseFloat(gift.variants[0].compare_at_price || gift.variants[0].price);
          if(origPrice > 0) giftOrig.textContent = '$' + origPrice.toFixed(2);
        }
      }
    });

  window.bwFlavor = function(i){
    selF = i;
    document.querySelectorAll('.flavor-card').forEach(function(c,idx){
      c.classList.toggle('active', idx===i);
      document.getElementById('bw-fc-'+idx).classList.toggle('on', idx===i);
    });
    if(typeof window.bwUpdateImage === 'function'){ window.bwUpdateImage(i); }
    bwUpdate();
  };

  window.bwQty = function(i){
    selQ = i;
    document.querySelectorAll('.qty-card').forEach(function(c,idx){ c.classList.toggle('active', idx===i); });
    bwUpdate();
  };

  function bwUpdate(){
    var qty   = QTYS[selQ];
    var disc  = DISCOUNTS[selQ];
    var sub   = parseFloat((UNIT_PRICE * qty).toFixed(2));
    var save  = parseFloat((sub * disc).toFixed(2));
    var total = parseFloat((sub - save).toFixed(2));
    var per   = parseFloat((total / qty).toFixed(2));

    document.getElementById('bw-items').textContent = qty + ' bag' + (qty > 1 ? 's' : '') + ' · ' + FLAVORS[selF];
    document.getElementById('bw-orig').textContent  = '$' + sub.toFixed(2);
    document.getElementById('bw-total').textContent = '$' + total.toFixed(2);
    document.getElementById('bw-per').textContent   = '$' + per.toFixed(2) + ' per bag';

    var discRow = document.getElementById('bw-discount-row');
    var giftRow = document.getElementById('bw-gift-row');
    if(disc > 0){
      discRow.classList.remove('hidden');
      document.getElementById('bw-disc-lbl').textContent = 'Bundle discount (' + (disc * 100) + '%)';
      document.getElementById('bw-disc-amt').textContent = '-$' + save.toFixed(2);
    } else {
      discRow.classList.add('hidden');
    }
    // Show free gift row for qty >= 2
    giftRow.classList.toggle('hidden', qty < 2);
    // Show/hide gift banner
    var giftBox = document.getElementById('bw-gift-box');
    if(giftBox) giftBox.classList.toggle('visible', qty >= 2);

    var btn = document.getElementById('bw-btn');
    btn.textContent = 'Buy Now →';
    btn.classList.remove('success','loading');
  }

  window.bwAddCart = function(){
    var variantId = VARIANT_IDS[selF];
    var qty       = QTYS[selQ];
    var btn       = document.getElementById('bw-btn');
    var includeGift = qty >= 2;

    btn.textContent = 'Going to checkout...';
    btn.classList.add('loading');

    // Build items array — always add main product, add free gift if qty >= 2
    var items = [{ id: variantId, quantity: qty }];
    if(includeGift){
      items.push({ id: FREE_GIFT_VARIANT_ID, quantity: 1 });
    }

    // First clear any existing free gift from cart to avoid duplicates
    fetch('/cart/update.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ updates: { [FREE_GIFT_VARIANT_ID]: 0 } })
    })
    .then(function(){
      // Add all items to cart
      return fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: items })
      });
    })
    .then(function(){
      // Go straight to checkout — bypasses cart page
      window.location.href = '/checkout';
    })
    .catch(function(){
      btn.textContent = 'Buy Now →';
      btn.classList.remove('loading');
      alert('Something went wrong. Please try again.');
    });
  };

  bwUpdate();
})();
</script>
