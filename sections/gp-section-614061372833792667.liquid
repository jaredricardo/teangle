    mainBox.innerHTML  = '';
    thumbRow.innerHTML = '';

    items.forEach(function(item, i){
      var isActive = (i === activeIdx);

      if(item.type === 'video'){
        var vid         = document.createElement('video');
        vid.src         = item.src;
        vid.poster      = item.poster || '';
        vid.className   = 'bw-main-media' + (isActive ? ' bw-active' : '');
        vid.controls    = true;
        vid.playsInline = true;
        vid.preload     = 'metadata';
        mainBox.appendChild(vid);
      } else {
        var img       = document.createElement('img');
        img.src       = item.src;
        img.alt       = 'Product ' + (i + 1);
        img.className = 'bw-main-media' + (isActive ? ' bw-active' : '');
        mainBox.appendChild(img);
      }

      var wrap       = document.createElement('div');
      wrap.className = 'bw-thumb-wrap';
      wrap.onclick   = (function(idx){ return function(){ bwSelectMedia(idx); }; })(i);

      var th         = document.createElement('img');
      th.src         = item.poster || item.src;
      th.className   = 'bw-thumb' + (isActive ? ' bw-active' : '');
      th.alt         = (item.type === 'video' ? 'Video' : 'Image') + ' ' + (i + 1);
      wrap.appendChild(th);

      if(item.type === 'video'){
        var pi = document.createElement('div');
        pi.className = 'bw-play-icon';
        pi.innerHTML = '<svg viewBox="0 0 10 10" fill="white"><polygon points="2,1 9,5 2,9"/></svg>';
        wrap.appendChild(pi);
      }

      thumbRow.appendChild(wrap);
    });

    // Auto scroll active thumb into view on mobile
    var activeThumb = thumbRow.querySelectorAll('.bw-thumb-wrap')[activeIdx];
    if(activeThumb){
      setTimeout(function(){
        activeThumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      }, 50);
    }
  }

  function bwSelectMedia(idx){
    document.querySelectorAll('#bw-main-box video').forEach(function(v){ v.pause(); });
    render(currentFlavor, idx);
  }
  window.bwImgSelect = bwSelectMedia;

  function showUI(){
    document.getElementById('bw-skeleton').style.display = 'none';
    document.getElementById('bw-main-box').style.display  = 'block';
    document.getElementById('bw-thumb-row').style.display = 'flex';
  }

  function parseProductMedia(productData, flavorIdx){
    var mediaArr = productData.media || [];
    mediaArr.forEach(function(m){
      if(m.media_type === 'image'){
        var src = m.src || (m.preview_image && m.preview_image.src);
        if(src) allMedia[flavorIdx].push({ type:'image', src: src });
      } else if(m.media_type === 'video'){
        var sources = m.sources || [];
        var mp4 = sources.filter(function(s){ return s.mime_type === 'video/mp4'; });
        mp4.sort(function(a,b){ return (b.width||0) - (a.width||0); });
        var best   = mp4[0] || sources[0];
        var poster = m.preview_image && m.preview_image.src ? m.preview_image.src : '';
        if(best) allMedia[flavorIdx].push({ type:'video', src: best.url, poster: poster });
      }
    });
  }

  fetch('/products.json?limit=250')
    .then(function(r){ return r.json(); })
    .then(function(data){
      var products = data.products || [];

      var giftImgEl = document.getElementById('bw2-gift-img');
      if(giftImgEl){
        var giftProd = products.find(function(p){
          return p.variants && p.variants.some(function(v){ return v.id === FREE_GIFT_VARIANT; });
        });
        if(giftProd && giftProd.images && giftProd.images.length){
          giftImgEl.src = giftProd.images[0].src;
        }
      }

      var handles = PRODUCT_IDS.map(function(id){
        var match = products.find(function(p){ return p.id === id; });
        return match ? match.handle : null;
      });

      var fetches = handles.map(function(handle, idx){
        if(!handle) return Promise.resolve();
        return fetch('/products/' + handle + '.js')
          .then(function(r){ return r.json(); })
          .then(function(productData){ parseProductMedia(productData, idx); })
          .catch(function(){});
      });

      return Promise.all(fetches);
    })
    .then(function(){
      render(0, 0);
      showUI();
    })
    .catch(function(){
      render(0, 0);
      showUI();
    });

  window.bwUpdateImage = function(flavorIdx){
    document.querySelectorAll('#bw-main-box video').forEach(function(v){ v.pause(); });
    currentFlavor = flavorIdx;
    render(flavorIdx, 0);
  };

})();
</script>
