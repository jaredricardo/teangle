<style>
  .ss-table,
  .ss-table * {
    box-sizing: border-box;
    font-family: "Poppins", system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
  }

  .ss-wrap {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 0px 0;
    background: transparent;
  }

  .ss-table {
    width: min(920px, 100%);
    border-radius: 18px;
    overflow: hidden;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.10);
    box-shadow: none;
  }

  /* Header */
  .ss-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: #F9F1E8;
    color: #2D2926;
  }

  .ss-head div {
    padding: 16px 14px;
    text-align: center;
    font-size: 18px;
    font-weight: 700;
  }

  .ss-head div:first-child {
    border-right: 1px solid rgba(255, 255, 255, 0.35);
  }

  /* Rows */
  .ss-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: 1px solid #f0f0f0;
  }

  .ss-left,
  .ss-right {
    padding: 20px 14px;
    display: flex;
    align-items: center;
  }

  .ss-left {
    justify-content: flex-start;   /* left align content */
  text-align: left;              /* left align text */
  font-weight: 400;
  font-size: 16px;
  color: #111111;
  background: #ffffff;
  border-right: 1px solid #f0f0f0;
  padding-left: 24px;            /* extra inset so it matches the right side */
}

  /* Right column: tick + text */
  .ss-right {
    justify-content: flex-start;
    gap: 10px;
    background: #F9A0C4;
  }

  .ss-support-text {
    margin: 0;
    font-size: 15px;
    line-height: 1.35;
    color: #111111;
    font-weight: 400;
    flex: 1 1 auto;
    min-width: 0;
  }

  /* TICK ONLY (no circle) */
.ss-check{
  width: auto;
  height: auto;
  border-radius: 0;
  background: transparent;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  margin-top: 0; /* default (desktop) */
}

/* Mobile only: bring tick down a bit */
@media (max-width: 600px){
  .ss-check{
    margin-top: 5px;
  }
}

  .ss-check svg{
    width: 18px;
    height: 18px;
    display: block;
  }

  /* Mobile-only line break after weak */
  br.ss-br-mobile { display: none; }

  /* Mobile */
  @media (max-width: 600px) {
    .ss-left {
      justify-content: flex-start;
      text-align: left;
      font-size: 16px;
      padding-left: 14px;
    }

    .ss-right {
      align-items: flex-start;
      gap: 8px;
    }

    .ss-support-text {
      font-size: 14px;
    }

    br.ss-br-mobile { display: block; }
  }

  /* EXTRA-NARROW PHONES (iPhone 12/13/14 width range) */
  @media (max-width: 410px) {
    /* give Supports a bit more width */
    .ss-head { grid-template-columns: 0.9fr 1.1fr; }
    .ss-row  { grid-template-columns: 0.9fr 1.1fr; }

    /* reclaim a few px */
    .ss-left, .ss-right { padding: 18px 12px; }
    .ss-right { gap: 7px; }

    /* tiny size tweak */
    .ss-support-text { font-size: 13.5px; line-height: 1.32; }
