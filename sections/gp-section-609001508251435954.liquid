      <div>
    <!-- GlowActiv Science Section (DESKTOP ONLY / CRO POLISHED + WORKING PROGRESS BARS) -->

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<!-- Body font (Poppins) -->
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<!-- Heading font (Lora) -->
<link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  /* Desktop only */
  #ga-science-desktop { display: none !important; }
  @media (min-width: 991px){
    #ga-science-desktop { display: block !important; }
  }

  #ga-science-desktop,
  #ga-science-desktop *{
    font-family: "Poppins", sans-serif !important; /* Default body font */
    box-sizing: border-box !important;
  }

  /* ===============================
     FONT OVERRIDES
     Headings = Lora
     Body = Poppins
  ============================== */
  #ga-science-desktop h1,
  #ga-science-desktop h2,
  #ga-science-desktop h3,
  #ga-science-desktop h4,
  #ga-science-desktop h5,
  #ga-science-desktop h6,
  #ga-science-desktop .ga-sci-title,
  #ga-science-desktop .ga-sci-subtitle,
  #ga-science-desktop .ga-why-title,
  #ga-science-desktop .ga-phase-title{
    font-family: "Lora", serif !important;
    letter-spacing: -0.2px !important;
  }

  #ga-science-desktop p,
  #ga-science-desktop .ga-sci-desc,
  #ga-science-desktop .ga-phase-text,
  #ga-science-desktop .ga-why-text{
    font-family: "Poppins", sans-serif !important;
  }

  #ga-science-desktop{
    width: 100% !important;
    padding: 52px 18px !important;
  }

  .ga-sci-wrap{
    max-width: 1180px !important;
    margin: 0 auto !important;
  }

  /* Header */
  .ga-sci-head{
    text-align: center !important;
    margin-bottom: 22px !important;
  }
  .ga-sci-title{
    font-size: 45px !important;
    line-height: 1.08 !important;
    font-weight: 700 !important;
    color: #2D2926 !important;
    margin: 0 !important;
    letter-spacing: -0.5px !important;
  }
  .ga-sci-subtitle{
    font-size: 22px !important;
    line-height: 1.2 !important;
    font-weight: 800 !important;
    color: #2D2926 !important;
    margin: 10px 0 0 0 !important;
  }
  .ga-sci-desc{
    font-size: 16px !important; /* was 15px */
    line-height: 1.6 !important;
    color: #111111 !important;
    margin: 12px 0 0 0 !important;
    opacity: .9 !important;
  }

  /* Main grid */
  .ga-sci-grid{
    display: grid !important;
    grid-template-columns: 1fr 320px !important;
    gap: 18px !important;
    align-items: stretch !important;
    margin-top: 22px !important;
  }

  .ga-sci-left{
    display: grid !important;
    grid-template-rows: auto auto !important;
    gap: 18px !important;
  }

  /* Phase row */
  .ga-phase-row{
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 18px !important;
    align-items: stretch !important;
  }

  /* Card base */
  .ga-card{
    background: #ffffff !important;
    border: 1px solid rgba(0,0,0,.10) !important;
    border-radius: 16px !important;
    box-shadow: 0 12px 26px rgba(0,0,0,.06) !important;
    padding: 18px 18px 16px 18px !important;
    min-height: 198px !important;
    display: flex !important;
    flex-direction: column !important;
    justify-content: space-between !important;
  }

  /* Phase top content */
  .ga-phase-top{
    display: grid !important;
    grid-template-columns: 72px 1fr !important;
    gap: 12px !important;
    align-items: center !important;
  }

  /* Icon circle (bigger + fills) */
  .ga-ico{
    width: 72px !important;
    height: 72px !important;
    border-radius: 999px !important;
    background: rgba(250,46,125,.10) !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    overflow: hidden !important;
    flex: 0 0 72px !important;
    box-shadow: 0 6px 14px rgba(250,46,125,.14) !important;
  }
  .ga-ico img{
    width: 100% !important;
    height: 100% !important;
    object-fit: contain !important;
    padding: 12px !important;
    display: block !important;
  }

  .ga-phase-title{
    margin: 0 !important;
    font-size: 17px !important; /* was 14px */
    line-height: 1.2 !important;
    font-weight: 800 !important;
    color: #FA2E7D !important;
  }
  .ga-phase-text{
    margin: 6px 0 0 0 !important;
    font-size: 13px !important;
    line-height: 1.4 !important;
    color: #111111 !important;
    font-weight: 500 !important;
  }
  .ga-phase-text b{
    font-weight: 800 !important;
  }

  /* Progress bar (uses CSS variable so it always fills correctly) */
  .ga-slider{
    position: relative !important;
    height: 8px !important;
    border-radius: 999px !important;
    background: #2A2A2A !important;
    overflow: hidden !important;
    margin-top: 14px !important;
    --ga-pct: 0%;
  }
  .ga-slider .ga-fill{
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    height: 100% !important;
    width: var(--ga-pct) !important;
    background: #FA2E7D !important;
    border-radius: 999px !important;
    transition: width .35s ease !important;
  }
  .ga-slider .ga-knob{
    position: absolute !important;
    top: 50% !important;
    left: var(--ga-pct) !important;
    transform: translate(-50%, -50%) !important;
    width: 16px !important;
    height: 16px !important;
    border-radius: 999px !important;
    background: #ffffff !important;
    border: 3px solid #FA2E7D !important;
    box-shadow: 0 8px 18px rgba(0,0,0,.14) !important;
    transition: left .35s ease !important;
  }

  /* Why 3-in-1 */
  .ga-why{
    background: #ffffff !important;
    border: 1px solid rgba(0,0,0,.10) !important;
    border-radius: 16px !important;
    box-shadow: 0 12px 26px rgba(0,0,0,.06) !important;
    padding: 16px 18px !important;
  }
  .ga-why-title{
    text-align: center !important;
    margin: 0 !important;
    font-size: 19px !important; /* was 18px */
    font-weight: 800 !important;
    color: #000 !important;
  }

  .ga-why-row{
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 12px !important;
    margin-top: 14px !important;
    align-items: center !important;
