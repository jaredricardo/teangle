<script>
(function () {
  function clamp(n, min, max){ return Math.max(min, Math.min(max, n)); }

  function initBars(scope){
    var root = (scope && scope.querySelector) ? scope : document;
    var bars = root.querySelectorAll('#ga-science-desktop .ga-slider[data-progress]');
    for (var i = 0; i < bars.length; i++){
      var bar = bars[i];
      var pct = parseFloat(bar.getAttribute('data-progress')) || 0;
      pct = clamp(pct, 0, 100);
      bar.style.setProperty('--ga-pct', pct + '%');
    }
  }

  function ready(fn){
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', fn);
    } else {
      fn();
    }
  }

  ready(function(){ initBars(document); });

  document.addEventListener('shopify:section:load', function(e){ initBars(e.target); });

  /* GemPages sometimes injects content after load */
  var mo = new MutationObserver(function(){
    initBars(document);
  });
  mo.observe(document.documentElement, { childList: true, subtree: true });
})();
</script>
